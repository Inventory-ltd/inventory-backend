# Development Dockerfile for NestJS with hot reload
FROM node:22-alpine

# Create app directory
WORKDIR /usr/src/app

# Environment
ENV NODE_ENV=developmentfromdockerfile
ENV PORT=3000

# Install dependencies first (better layer caching)
COPY package*.json ./
RUN npm install

# Copy the rest of the source code
COPY . .

# Expose app port
EXPOSE 3000

# Default command: start in watch mode
CMD ["npm", "run", "start:dev"]
